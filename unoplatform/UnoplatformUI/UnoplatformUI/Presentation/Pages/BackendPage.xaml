<Page x:Class="UnoplatformUI.Presentation.Pages.BackendPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoplatformUI.Presentation.Pages"
      NavigationCacheMode="Disabled"
      Background="{ThemeResource BackgroundBrush}">
  <ScrollViewer>
    <StackPanel Padding="20" Spacing="12">

      <TextBlock Text="Backend" FontSize="22" FontWeight="Bold" />

      <TextBlock Text="Currently in use" FontWeight="SemiBold" />
      <TextBlock Text="{Binding CurrentAddress}" Foreground="Gray" FontSize="16" />

      <Border Height="1" Background="LightGray" Margin="0,8" />

      <TextBlock Text="Host (IP or name)" FontWeight="SemiBold" />
      <TextBox Text="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="localhost" />

      <TextBlock Text="Port" FontWeight="SemiBold" />
      <TextBox Text="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               InputScope="Number" PlaceholderText="5080" />

      <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
        <Button Content="Reload" Command="{Binding ReloadCommand}" />
        <Button Content="Save" Command="{Binding SaveCommand}" />
      </StackPanel>

      <TextBlock Text="{Binding Status}" Foreground="Gray" />

      <Border Height="1" Background="LightGray" Margin="0,8" />
      <TextBlock Foreground="Gray" FontSize="12" TextWrapping="Wrap"
                 Text="Saving rebuilds the gRPC channel immediately. Switching to any other tab refetches against the new endpoint." />
    </StackPanel>
  </ScrollViewer>
</Page>
