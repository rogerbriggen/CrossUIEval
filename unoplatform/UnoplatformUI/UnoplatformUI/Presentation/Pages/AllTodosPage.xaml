<Page x:Class="UnoplatformUI.Presentation.Pages.AllTodosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoplatformUI.Presentation.Pages"
      xmlns:grpc="using:BackendUiEval.Grpc"
      NavigationCacheMode="Disabled"
      Background="{ThemeResource BackgroundBrush}">
  <Page.Resources>
    <local:TimestampDisplayConverter x:Key="TimestampDisplay" />
  </Page.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="All (Person1)" FontSize="22" FontWeight="Bold" Padding="16,12,16,0" />

    <Button Grid.Row="1" Content="Refresh" Command="{Binding RefreshCommand}"
            Margin="16,8,16,4" />

    <ListView Grid.Row="2" ItemsSource="{Binding Todos}"
              SelectionMode="Single"
              ItemClick="OnItemClick"
              IsItemClickEnabled="True">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="0,6">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding Date, Converter={StaticResource TimestampDisplay}}" FontWeight="SemiBold" />
              <TextBlock Grid.Column="1" Text="{Binding Type}" Foreground="Gray" />
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding Description}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <TextBlock Grid.Row="3" Text="{Binding Status}" Foreground="Gray" Padding="16,8" />
  </Grid>
</Page>
