<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiUiEval.ViewModels"
             x:Class="MauiUiEval.Views.BackendPage"
             x:DataType="vm:BackendViewModel"
             Title="Backend">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Backend gRPC endpoint" FontAttributes="Bold" FontSize="20" />
            <Label Text="Currently in use:" />
            <Label Text="{Binding CurrentAddress}" TextColor="Gray" FontSize="16" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Host (IP or name)" FontAttributes="Bold" />
            <Entry Text="{Binding Host}" Placeholder="localhost" />

            <Label Text="Port" FontAttributes="Bold" />
            <Entry Text="{Binding Port}" Keyboard="Numeric" Placeholder="5080" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">
                <Button Grid.Column="0" Text="Reload" Command="{Binding ReloadCommand}" />
                <Button Grid.Column="1" Text="Save" Command="{Binding SaveCommand}" />
            </Grid>

            <Label Text="{Binding Status}" TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />
            <Label Text="Saving rebuilds the gRPC channel immediately. Switching to any other tab refetches against the new endpoint."
                   TextColor="Gray" FontSize="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
