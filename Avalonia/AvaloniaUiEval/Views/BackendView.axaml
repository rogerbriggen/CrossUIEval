<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaUiEval.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="AvaloniaUiEval.Views.BackendView"
             x:DataType="vm:BackendViewModel">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="Backend" FontSize="22" FontWeight="SemiBold" />

        <TextBlock Text="Current" Foreground="Gray" />
        <TextBlock Text="{Binding CurrentAddress}" FontFamily="Consolas,monospace" />

        <TextBlock Text="Host" />
        <TextBox Text="{Binding Host, Mode=TwoWay}" PlaceholderText="localhost" />

        <TextBlock Text="Port" />
        <NumericUpDown Value="{Binding Port, Mode=TwoWay}" Minimum="1" Maximum="65535" Increment="1" FormatString="0" HorizontalAlignment="Left" Width="160" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Save" Command="{Binding SaveCommand}" />
            <Button Content="Reload from client" Command="{Binding ReloadCommand}" />
        </StackPanel>

        <TextBlock Text="{Binding Status}" Foreground="Gray" TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
