<Page x:Class="UnoplatformUI.Presentation.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoplatformUI.Presentation.Pages"
      xmlns:grpc="using:BackendUiEval.Grpc"
      NavigationCacheMode="Disabled"
      Background="{ThemeResource BackgroundBrush}">
  <ScrollViewer>
    <StackPanel Padding="20" Spacing="12">

      <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" />

      <TextBlock Text="Viewing settings for" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ToggleButton Content="Person1" IsChecked="{Binding IsPerson1, Mode=TwoWay}" Click="OnPersonToggle" Tag="Person1" />
        <ToggleButton Content="Person2" IsChecked="{Binding IsPerson2, Mode=TwoWay}" Click="OnPersonToggle" Tag="Person2" />
      </StackPanel>

      <Border Height="1" Background="LightGray" />

      <TextBlock Text="Accent color (tap to select)" FontWeight="SemiBold" />
      <TextBlock Text="{Binding AccentColorLabel}" Foreground="Gray" FontSize="12" />
      <ScrollViewer HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled"
                    HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding AccentColors}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="10" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="local:AccentChipVm">
              <Border Width="90" Height="50" CornerRadius="10"
                      Background="{x:Bind Brush}"
                      BorderBrush="{x:Bind StrokeBrush, Mode=OneWay}"
                      BorderThickness="{x:Bind StrokeThickness, Mode=OneWay}"
                      Tag="{x:Bind Value}">
                <Border.Resources>
                  <Style TargetType="Border">
                  </Style>
                </Border.Resources>
                <Grid>
                  <Grid.Background>
                    <SolidColorBrush Color="Transparent" />
                  </Grid.Background>
                  <Grid Tapped="OnChipTapped" Background="Transparent">
                    <TextBlock Text="{x:Bind Name}" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <Border Height="1" Background="LightGray" />

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Notifications enabled" VerticalAlignment="Center" />
        <ToggleSwitch Grid.Column="1" IsOn="{Binding NotificationsEnabled, Mode=TwoWay}" />
      </Grid>
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Dark mode" VerticalAlignment="Center" />
        <ToggleSwitch Grid.Column="1" IsOn="{Binding DarkMode, Mode=TwoWay}" />
      </Grid>
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Show completed todos" VerticalAlignment="Center" />
        <ToggleSwitch Grid.Column="1" IsOn="{Binding ShowCompletedTodos, Mode=TwoWay}" />
      </Grid>

      <Border Height="1" Background="LightGray" />

      <TextBlock Text="Display name" FontWeight="SemiBold" />
      <TextBox Text="{Binding DisplayName, Mode=TwoWay}" />
      <TextBlock Text="Email" FontWeight="SemiBold" />
      <TextBox Text="{Binding Email, Mode=TwoWay}" />

      <TextBlock Text="Signature" FontWeight="SemiBold" />
      <TextBox Text="{Binding Signature, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
      <TextBlock Text="Default detail template" FontWeight="SemiBold" />
      <TextBox Text="{Binding DefaultDetailTemplate, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" Height="100" />

      <TextBlock Text="Default todo type" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding TodoTypes}" SelectedItem="{Binding DefaultTodoType, Mode=TwoWay}" />
      <TextBlock Text="Default state" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding TodoStates}" SelectedItem="{Binding DefaultState, Mode=TwoWay}" />
      <TextBlock Text="Language" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Language, Mode=TwoWay}" />
      <TextBlock Text="Page size" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding PageSizes}" SelectedItem="{Binding PageSize, Mode=TwoWay}" />

      <Border Height="1" Background="LightGray" />

      <TextBlock Text="User ID" FontWeight="SemiBold" />
      <TextBlock Text="{Binding UserId}" Foreground="Gray" />
      <TextBlock Text="Account created" FontWeight="SemiBold" />
      <TextBlock Text="{Binding AccountCreated}" Foreground="Gray" />
      <TextBlock Text="Todo count" FontWeight="SemiBold" />
      <TextBlock Text="{Binding TodoCount}" Foreground="Gray" />
      <TextBlock Text="App version" FontWeight="SemiBold" />
      <TextBlock Text="{Binding AppVersion}" Foreground="Gray" />

      <Grid ColumnSpacing="10" Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="Reload" Command="{Binding ReloadCommand}" HorizontalAlignment="Stretch" />
        <Button Grid.Column="1" Content="Save" Command="{Binding SaveCommand}" HorizontalAlignment="Stretch" />
      </Grid>

      <TextBlock Text="{Binding Status}" Foreground="Gray" />

    </StackPanel>
  </ScrollViewer>
</Page>
