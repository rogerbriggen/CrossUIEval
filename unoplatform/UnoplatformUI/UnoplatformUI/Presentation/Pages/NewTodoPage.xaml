<Page x:Class="UnoplatformUI.Presentation.Pages.NewTodoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoplatformUI.Presentation.Pages"
      NavigationCacheMode="Disabled"
      Background="{ThemeResource BackgroundBrush}">
  <ScrollViewer>
    <StackPanel Padding="20" Spacing="12">
      <TextBlock Text="New todo" FontSize="22" FontWeight="Bold" />

      <TextBlock Text="Description" FontWeight="SemiBold" />
      <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="What needs doing?" />

      <TextBlock Text="Detail" FontWeight="SemiBold" />
      <TextBox Text="{Binding Detail, Mode=TwoWay}"
               AcceptsReturn="True" TextWrapping="Wrap" Height="120" />

      <TextBlock Text="Type" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding TodoTypes}" SelectedItem="{Binding Type, Mode=TwoWay}" />

      <TextBlock Text="Person" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding Persons}" SelectedItem="{Binding Person, Mode=TwoWay}" />

      <TextBlock Text="State" FontWeight="SemiBold" />
      <ComboBox ItemsSource="{Binding States}" SelectedItem="{Binding State, Mode=TwoWay}" />

      <Button Content="Create" Command="{Binding SubmitCommand}" Margin="0,12,0,0" />
      <TextBlock Text="{Binding Status}" Foreground="Gray" />
    </StackPanel>
  </ScrollViewer>
</Page>
